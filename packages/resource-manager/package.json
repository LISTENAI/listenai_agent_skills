{
  "name": "@listenai/eaw-resource-manager",
  "version": "0.0.2",
  "maintainers": [
    {
      "name": "lpmadmin"
    }
  ],
  "type": "module",
  "bin": {
    "resource-manager": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
