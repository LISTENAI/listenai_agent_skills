    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@listenai/eaw-contracts": "workspace:*",
    "hono": "^4.12.9"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
