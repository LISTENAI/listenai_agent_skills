{
  "name": "@listenai/eaw-skill-logic-analyzer",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./claude-skill-installer": {
      "types": "./dist/claude-skill-installer.d.ts",
      "import": "./dist/claude-skill-installer.js"
    },
    "./codex-skill-installer": {
      "types": "./dist/codex-skill-installer.d.ts",
      "import": "./dist/codex-skill-installer.js"
    },
    "./package.json": "./package.json",
    "./SKILL.md": "./SKILL.md",
    "./README.md": "./README.md"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "SKILL.md",
    "README.md",
    "package.json"
  ],
  "bin": {
    "listenai-logic-analyzer-install-claude": "./dist/claude-skill-install-cli.js",
    "listenai-logic-analyzer-install-codex": "./dist/codex-skill-install-cli.js"
  },
  "listenai": {
    "skillAssets": {
      "skillDescriptor": "./SKILL.md",
      "readme": "./README.md"
    }
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.build.tsbuildinfo && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@listenai/eaw-contracts": "workspace:*"
  },
  "devDependencies": {
    "@listenai/eaw-resource-manager": "workspace:*",
    "@types/node": "^25.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
